{
  "hosting": {
    "site": "billingonaire",
    "public": "billingonaire-ui/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "billingonaire-backend",
      "runtime": "python310",
      "codebase": "default"
    },
    {
      "source": "billingonaire",
      "codebase": "backend",
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
